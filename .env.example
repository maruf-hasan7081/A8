# MongoDB Atlas or local MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/leaf-and-lore
MONGODB_DB_NAME=leaf_and_lore

# Better Auth
# Generate a strong value with: npx auth@latest secret
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (Google Cloud Console > OAuth 2.0 Client IDs)
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
